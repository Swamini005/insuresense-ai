# ══════════════════════════════════════════════════════════════
# InsureSense – Environment Variables
# ══════════════════════════════════════════════════════════════
#
# Frontend (Vite) variables live here in the project root.
# Backend variables live in backend/.env (see backend/.env.example).
#
# ── Frontend (Vite) ────────────────────────────────────────
# Base URL the React app uses to reach the backend.
# In local dev with the Vite proxy, this can be left empty.
# Set to the full backend URL for production builds.
VITE_API_URL=http://localhost:3000
