# ── LLM (Groq) ─────────────────────────────────────────────
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the default model
GROQ_MODEL=openai/gpt-oss-120b

# ── Database (Postgres via Knex) ───────────────────────────
# Either set DATABASE_URL...
# DATABASE_URL=postgres://user:password@host:5432/insuresense
# ...or the discrete vars below:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=insuresense
# Set to 'true' for managed Postgres that requires SSL (e.g. Neon, Supabase, RDS)
PGSSL=false

# ── Auth (JWT) ─────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────
# The origin your frontend runs on (Vite dev server default)
CORS_ORIGIN=http://localhost:5173
